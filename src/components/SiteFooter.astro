---
import { GitFork, Mail, Rss } from "@lucide/astro";
import { site } from "@/data/site";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="eyebrow">BID-AUTOMATION RELEASE NOTES</p>
      <h2>One useful note when the tool ships.</h2>
      <p>
        No spam. No popups. Release notes, field lessons, and public case-study
        numbers when they exist.
      </p>
      <div class="footer-links">
        <a href={site.docsUrl}>Docs</a>
        <a href={site.productRepo}>GitHub</a>
        <a href="/security">Security</a>
        <a href="/compare">Compare</a>
        <a href={site.xUrl}>X</a>
        <a href={site.youtubeUrl}>YouTube</a>
        <a href={site.personalSite}>contractorkeith.com</a>
      </div>
    </div>
    <div>
      <form
        class="email-form"
        action="https://buttondown.email/api/emails/embed-subscribe/contractorkeith"
        method="post"
        target="popupwindow"
      >
        <label class="eyebrow" for="footer-email">Email</label>
        <input
          id="footer-email"
          type="email"
          name="email"
          autocomplete="email"
          placeholder="you@company.com"
          required
        />
        <button class="button orange" type="submit">
          <Rss size={18} aria-hidden="true" />
          Subscribe
        </button>
      </form>
      <p>
        Made in Florida by a working estimator. Questions:
        <a href={`mailto:${site.supportEmail}`}>
          <Mail size={16} aria-hidden="true" /> {site.supportEmail}
        </a>
      </p>
      <p>
        <a href={site.siteRepo}>
          <GitFork size={16} aria-hidden="true" /> Site source
        </a>
      </p>
    </div>
  </div>
</footer>
