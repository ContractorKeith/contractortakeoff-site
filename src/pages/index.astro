---
import { BookOpen, Clipboard, GitFork, Mail, Wrench } from "@lucide/astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteNav from "@/components/SiteNav.astro";
import { site } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";

// Pixel icon glyphs (8x8 grid, fill inherits currentColor from the parent svg)
const px = {
  board:
    '<rect x="0" y="0" width="5" height="2"/><rect x="6" y="0" width="2" height="2"/><rect x="0" y="3" width="4" height="2"/><rect x="6" y="3" width="2" height="2"/><rect x="0" y="6" width="6" height="2"/>',
  docs: '<rect x="1" y="0" width="4" height="8"/><rect x="5" y="2" width="2" height="6"/>',
  link: '<rect x="0" y="3" width="3" height="3"/><rect x="5" y="2" width="3" height="3"/><rect x="3" y="3" width="2" height="2"/>',
  alert:
    '<rect x="3" y="0" width="2" height="5"/><rect x="3" y="6" width="2" height="2"/>',
  note: '<rect x="5" y="0" width="2" height="2"/><rect x="4" y="2" width="2" height="2"/><rect x="3" y="4" width="2" height="2"/><rect x="0" y="6" width="3" height="2"/>',
  export:
    '<rect x="3" y="0" width="2" height="4"/><rect x="1" y="2" width="2" height="2"/><rect x="5" y="2" width="2" height="2"/><rect x="0" y="6" width="8" height="2"/>',
  tools:
    '<rect x="0" y="3" width="8" height="5"/><rect x="3" y="1" width="2" height="2"/>',
  ruler:
    '<rect x="0" y="4" width="8" height="2"/><rect x="1" y="1" width="1" height="3"/><rect x="3" y="2" width="1" height="2"/><rect x="5" y="1" width="1" height="3"/><rect x="7" y="2" width="1" height="2"/>',
  table:
    '<rect x="0" y="0" width="3" height="3"/><rect x="5" y="0" width="3" height="3"/><rect x="0" y="5" width="3" height="3"/><rect x="5" y="5" width="3" height="3"/>',
  overlay:
    '<rect x="0" y="0" width="5" height="5"/><rect x="3" y="3" width="5" height="5" opacity="0.55"/>',
  pdf: '<rect x="0" y="0" width="5" height="8"/><rect x="5" y="3" width="3" height="2"/>',
  sync: '<rect x="1" y="0" width="5" height="2"/><rect x="6" y="1" width="2" height="2"/><rect x="2" y="6" width="5" height="2"/><rect x="0" y="5" width="2" height="2"/>',
};

// Contractor Takeoff feature blocks (product band A)
const takeoffFeatures = [
  {
    icon: px.board,
    label: "BID BOARD",
    text: "One shared board the whole team reads: status, due dates, owner, and the next action on every bid.",
  },
  {
    icon: px.docs,
    label: "DOC LIBRARY",
    text: "Every bid gets its own document library: plans, specs, addenda, and bid forms in one place, versioned as they land.",
  },
  {
    icon: px.link,
    label: "SOURCE-BACKED TRIAGE",
    text: "AI-assisted triage reads the set and proposes findings. Every finding links to a source page you can open and verify.",
  },
  {
    icon: px.alert,
    label: "SCOPE + DEADLINE ALERTS",
    text: "Addendum detected, specs missing, due date closing in. The board tells you before the GC does.",
  },
  {
    icon: px.note,
    label: "NOTES + DECISIONS",
    text: "Team notes and dated decisions live on the bid, so 'why did we exclude that' has an answer in October.",
  },
  {
    icon: px.export,
    label: "BID PACKET EXPORT",
    text: "Deterministic export: same inputs, same packet, every time. Ready for suppliers and the GC.",
  },
];

// Plan Markup feature blocks (product band B)
const markupFeatures = [
  {
    icon: px.tools,
    label: "FULL MARKUP TOOLSET",
    text: "Clouds, callouts, stamps, highlights: the working set, with reusable tool chest presets for your trade.",
  },
  {
    icon: px.ruler,
    label: "MEASURE EVERYTHING",
    text: "Length, area, volume, and count, with per-page scale and scale regions for split-scale sheets.",
  },
  {
    icon: px.table,
    label: "TAKEOFF TOTALS TO CSV",
    text: "Running totals by tool and by page, exported straight to CSV for your pricing workbook.",
  },
  {
    icon: px.overlay,
    label: "OVERLAY + TRANSFER",
    text: "Overlay the new sheet on the old one when addenda land, then transfer your markups across.",
  },
  {
    icon: px.pdf,
    label: "REVU-COMPATIBLE EXPORT",
    text: "Export flattened PDFs, or editable PDFs that round-trip with teams still on Bluebeam Revu.",
  },
  {
    icon: px.sync,
    label: "LOCAL SIDECAR FILES",
    text: "Markups save as local sidecar files next to the PDF and sync through Dropbox or iCloud.",
  },
];

const faqs = [
  {
    question: "Is the app live?",
    answer:
      "No. Contractor Takeoff is in pilot, not public yet. Join the pilot list and we set you up on a call.",
  },
  {
    question: "Where do my documents go?",
    answer:
      "The free engine works in a folder on your machine: nothing uploads. The hosted app keeps bid documents in private storage scoped to your workspace. The Security page spells out the details.",
  },
  {
    question: "Will it price the job?",
    answer:
      "No. Pricing is your judgment. The suite clears the document shuffle so pricing starts sooner.",
  },
  {
    question: "Does it do takeoff measurement?",
    answer:
      "Plan Markup measures when you draw the measurement: length, area, volume, count, with per-page scale. Nothing guesses quantities for you.",
  },
  {
    question: "Does Plan Markup replace Bluebeam?",
    answer:
      "It replaces the 10 percent of Revu estimators use daily: markup, measure, overlay, export. Exports are flattened or Revu-compatible editable PDFs, so you can still trade files with Revu shops.",
  },
  {
    question: "What about Windows?",
    answer:
      "Plan Markup runs on Mac and in the browser today. Windows users can run the browser app.",
  },
  {
    question: "What if Keith disappears?",
    answer:
      "The engine is MIT-licensed and your bids are local files. You keep your data, your workflows, and every packet you generated.",
  },
  {
    question: "What does the free engine do without the app?",
    answer:
      "The full document pipeline: triage a bid package, isolate scope pages, pull specs, build the takeoff workbook, flag scope drift, and zip the supplier sendoff. CLI and MCP server, on your machine.",
  },
];
---

<BaseLayout>
  <SiteNav />
  <main id="main-content">
    <!-- 1. Hero: copy + dual app mockups -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow reveal">FOR SPECIALTY SUBCONTRACTORS</p>
          <h1 id="hero-title" class="reveal" style="--reveal-delay: 80ms">
            Run every bid from one command center.
          </h1>
          <p class="hero-sub lead reveal" style="--reveal-delay: 160ms">
            Contractor Takeoff is the bid command center, now in pilot. Plan
            Markup measures and marks up the sheets. Underneath both: a free
            open-source engine that runs where your plans already live, on
            your machine.
          </p>
          <div class="hero-actions reveal" style="--reveal-delay: 240ms">
            <a
              class="button steel"
              href={site.pilotHref}
              data-plausible-event-name="pilot_click"
            >
              <Mail size={18} aria-hidden="true" />
              Join the pilot
            </a>
            <a class="button ghost" href={site.productRepo}>
              <GitFork size={18} aria-hidden="true" />
              Star the free engine
            </a>
          </div>
          <p class="note reveal" style="--reveal-delay: 320ms">
            App in pilot. Engine free and MIT-licensed today.
          </p>
        </div>

        <div class="hero-media reveal" style="--reveal-delay: 200ms">
          <div class="mockup-stack">
            <!-- Dark card: Plan Markup canvas -->
            <div
              class="mockup markup-card"
              role="img"
              aria-label="Mockup of Plan Markup: a plan sheet with a measurement line drawing itself to a length of 128 feet 6 inches and a running takeoff total"
            >
              <div class="markup-titlebar" aria-hidden="true">
                <span>Plan Markup</span>
                <span class="mono">A-201.pdf</span>
              </div>
              <div class="markup-body" aria-hidden="true">
                <div class="markup-toolbar">
                  <span class="tool">
                    <svg viewBox="0 0 8 8" shape-rendering="crispEdges" fill="currentColor">
                      <rect x="1" y="0" width="2" height="6"></rect>
                      <rect x="3" y="2" width="2" height="2"></rect>
                      <rect x="5" y="4" width="2" height="2"></rect>
                    </svg>
                  </span>
                  <span class="tool active">
                    <svg viewBox="0 0 8 8" shape-rendering="crispEdges" fill="currentColor">
                      <rect x="0" y="6" width="2" height="2"></rect>
                      <rect x="2" y="4" width="2" height="2"></rect>
                      <rect x="4" y="2" width="2" height="2"></rect>
                      <rect x="6" y="0" width="2" height="2"></rect>
                    </svg>
                  </span>
                  <span class="tool">
                    <svg viewBox="0 0 8 8" shape-rendering="crispEdges" fill="currentColor">
                      <rect x="0" y="0" width="8" height="2"></rect>
                      <rect x="0" y="2" width="2" height="6"></rect>
                      <rect x="6" y="2" width="2" height="6"></rect>
                      <rect x="2" y="6" width="4" height="2"></rect>
                    </svg>
                  </span>
                  <span class="tool">
                    <svg viewBox="0 0 8 8" shape-rendering="crispEdges" fill="currentColor">
                      <rect x="3" y="1" width="2" height="6"></rect>
                      <rect x="1" y="3" width="6" height="2"></rect>
                    </svg>
                  </span>
                  <span class="tool">
                    <svg viewBox="0 0 8 8" shape-rendering="crispEdges" fill="currentColor">
                      <rect x="0" y="1" width="8" height="2"></rect>
                      <rect x="2" y="5" width="4" height="2"></rect>
                    </svg>
                  </span>
                </div>
                <div class="markup-sheet">
                  <svg viewBox="0 0 260 180" fill="none">
                    <!-- Faint plan linework -->
                    <rect
                      x="16"
                      y="14"
                      width="228"
                      height="150"
                      stroke="#CBD1D8"
                      stroke-width="1.5"></rect>
                    <path
                      d="M96 14 V88 M96 88 H16 M160 164 V110 M160 110 H244"
                      stroke="#DCE0E5"></path>
                    <path d="M96 44 a16 16 0 0 1 16 16" stroke="#E2E5E9"></path>
                    <path
                      d="M180 30 h40 M180 38 h40 M180 46 h24"
                      stroke="#E2E5E9"></path>
                    <circle cx="226" cy="140" r="9" stroke="#DCE0E5"></circle>
                    <!-- Measurement: draws itself in a loop -->
                    <polyline
                      class="measure-line"
                      points="36,150 36,60 148,60 148,104 222,104"
                      stroke="#2F6FB2"
                      stroke-width="2.5"
                      pathLength="100"></polyline>
                    <g class="measure-nodes" fill="#2F6FB2">
                      <rect x="33" y="147" width="6" height="6"></rect>
                      <rect x="33" y="57" width="6" height="6"></rect>
                      <rect x="145" y="57" width="6" height="6"></rect>
                      <rect x="145" y="101" width="6" height="6"></rect>
                      <rect x="219" y="101" width="6" height="6"></rect>
                    </g>
                  </svg>
                  <span class="measure-label mono">128'-6"</span>
                  <span class="markup-total mono">TOTAL 412 LF</span>
                </div>
              </div>
            </div>

            <!-- Light card: Contractor Takeoff bid board -->
            <div
              class="mockup board-card"
              role="img"
              aria-label="Mockup of the Contractor Takeoff bid board: four bids with due dates, status, and owner, and triage alerts appearing one at a time with source page tags"
            >
              <div class="board-head" aria-hidden="true">
                <span>Contractor Takeoff</span>
                <span class="mono">BID BOARD</span>
              </div>
              <div class="board-rows" aria-hidden="true">
                <div class="board-cols mono">
                  <span>PROJECT</span><span>GC</span><span>DUE</span><span
                    >STATUS</span
                  ><span></span>
                </div>
                <div class="board-row">
                  <span class="row-project">Riverside Fence Pkg</span>
                  <span class="row-gc">Turner</span>
                  <span class="pill due danger mono">Jul 18</span>
                  <span class="pill status warn">Triage</span>
                  <span class="owner">KB</span>
                </div>
                <div class="board-row">
                  <span class="row-project">Lakeview ES Ph 2</span>
                  <span class="row-gc">Ajax</span>
                  <span class="pill due mono">Jul 22</span>
                  <span class="pill status info">Measure</span>
                  <span class="owner">KB</span>
                </div>
                <div class="board-row">
                  <span class="row-project">SR-44 Guardrail</span>
                  <span class="row-gc">FDOT</span>
                  <span class="pill due mono">Jul 25</span>
                  <span class="pill status neutral">Draft</span>
                  <span class="owner">JM</span>
                </div>
                <div class="board-row">
                  <span class="row-project">Pinewood Apts</span>
                  <span class="row-gc">Core</span>
                  <span class="pill due mono">Aug 01</span>
                  <span class="pill status ok">Sent</span>
                  <span class="owner">KB</span>
                </div>
              </div>
              <div class="board-alerts" aria-hidden="true">
                <span class="alerts-tag mono">TRIAGE</span>
                <div class="alert-slot">
                  <div class="alert-row" style="--alert-delay: 0s">
                    <span class="alert-dot safety-dot"></span>
                    <span class="alert-text">Addendum 2 detected</span>
                    <code>A-201</code>
                  </div>
                  <div class="alert-row" style="--alert-delay: 3s">
                    <span class="alert-dot danger-dot"></span>
                    <span class="alert-text">Specs missing</span>
                    <code>Div 32</code>
                  </div>
                  <div class="alert-row" style="--alert-delay: 6s">
                    <span class="alert-dot warn-dot"></span>
                    <span class="alert-text">Due in 3 days</span>
                    <code>Riverside Fence Pkg</code>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. Problem strip -->
    <section class="proof-row" aria-label="Common bid setup problems">
      <div class="proof-cell">
        <p>
          400 pages and three addenda land, and the afternoon is gone before
          you can price a foot of work.
        </p>
      </div>
      <div class="proof-cell">
        <p>
          One missed addendum or one word of scope drift eats the whole
          margin.
        </p>
      </div>
      <div class="proof-cell">
        <p>
          Cloud AI tools want the GC's plan room uploaded. Your NDA disagrees.
        </p>
      </div>
    </section>

    <!-- 3. Product band A: Contractor Takeoff -->
    <section id="products" class="section" aria-labelledby="products-title">
      <div class="container split">
        <div class="reveal">
          <p class="eyebrow">SEC 01 / BID COMMAND CENTER</p>
          <h2 id="products-title">Contractor Takeoff</h2>
          <p class="lead">
            The whole bid on one board: documents, findings, deadlines,
            decisions, and the packet that goes out the door. Built for teams
            that bid every week.
          </p>
          <p class="status-note mono">In pilot now. Not public yet.</p>
        </div>
        <div class="feature-grid stagger">
          {
            takeoffFeatures.map(feature => (
              <div class="feature reveal">
                <span class="chip">
                  <svg
                    viewBox="0 0 8 8"
                    shape-rendering="crispEdges"
                    fill="currentColor"
                    aria-hidden="true"
                    set:html={feature.icon}
                  />
                  {feature.label}
                </span>
                <p>{feature.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <div class="dither-edge" aria-hidden="true"></div>

    <!-- 4. Product band B: Plan Markup (dark) -->
    <section
      id="plan-markup"
      class="section dark"
      aria-labelledby="markup-title"
    >
      <div class="container split">
        <div class="reveal">
          <p class="eyebrow">SEC 02 / MEASURE AND MARKUP</p>
          <h2 id="markup-title">Plan Markup</h2>
          <p class="lead">
            The daily Bluebeam workload: measure, mark up, overlay, export.
            You draw the measurement, it keeps the totals honest.
          </p>
          <p class="status-note mono">
            Runs on Mac and in the browser. Embeds inside Contractor Takeoff.
          </p>
        </div>
        <div class="feature-grid stagger">
          {
            markupFeatures.map(feature => (
              <div class="feature reveal">
                <span class="chip">
                  <svg
                    viewBox="0 0 8 8"
                    shape-rendering="crispEdges"
                    fill="currentColor"
                    aria-hidden="true"
                    set:html={feature.icon}
                  />
                  {feature.label}
                </span>
                <p>{feature.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <div class="dither-edge flip" aria-hidden="true"></div>

    <!-- 5. Better together: the embed story -->
    <section
      id="better-together"
      class="section"
      aria-labelledby="together-title"
    >
      <div class="container split">
        <div class="reveal">
          <p class="eyebrow">ONE SUITE</p>
          <h2 id="together-title">Markups that live with the bid.</h2>
          <p class="lead">
            Mark up a sheet on a bid and the markup stays with that bid.
            Measurements, alerts, notes, and the outgoing packet share one
            workspace, from invite to sendoff.
          </p>
        </div>
        <div
          class="flow-diagram reveal"
          style="--reveal-delay: 120ms"
          role="img"
          aria-label="Diagram: Plan Markup writes a sidecar JSON file, and Contractor Takeoff reads it into the bid workspace"
        >
          <div class="flow-box">
            <strong>Plan Markup</strong>
            <span>measure + mark up</span>
          </div>
          <svg
            class="flow-arrow"
            viewBox="0 0 12 8"
            shape-rendering="crispEdges"
            fill="currentColor"
            aria-hidden="true"
          >
            <rect x="0" y="3" width="7" height="2"></rect>
            <rect x="7" y="1" width="2" height="2"></rect>
            <rect x="7" y="5" width="2" height="2"></rect>
            <rect x="9" y="3" width="2" height="2"></rect>
          </svg>
          <div class="flow-box mono-box">
            <strong class="mono">sidecar.json</strong>
            <span>quantities + markups</span>
          </div>
          <svg
            class="flow-arrow"
            viewBox="0 0 12 8"
            shape-rendering="crispEdges"
            fill="currentColor"
            aria-hidden="true"
          >
            <rect x="0" y="3" width="7" height="2"></rect>
            <rect x="7" y="1" width="2" height="2"></rect>
            <rect x="7" y="5" width="2" height="2"></rect>
            <rect x="9" y="3" width="2" height="2"></rect>
          </svg>
          <div class="flow-box">
            <strong>Contractor Takeoff</strong>
            <span>bid workspace</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. How it works -->
    <section
      id="how-it-works"
      class="section tight"
      aria-labelledby="how-title"
    >
      <div class="container">
        <p class="eyebrow reveal">HOW IT WORKS</p>
        <h2 id="how-title" class="reveal" style="--reveal-delay: 80ms">
          Three moves per bid.
        </h2>
        <div class="how-grid stagger">
          <article class="how-step reveal">
            <span class="step-numeral" aria-hidden="true">1</span>
            <h3>Drop the docs.</h3>
            <p>
              Plans, specs, addenda, and bid forms go into the bid's document
              library. Originals stay untouched.
            </p>
          </article>
          <article class="how-step reveal">
            <span class="step-numeral" aria-hidden="true">2</span>
            <h3>Review, don't hunt.</h3>
            <p>
              Triage proposes scope pages, spec sections, and alerts, each
              linked to a source page. You approve what's real.
            </p>
          </article>
          <article class="how-step reveal">
            <span class="step-numeral" aria-hidden="true">3</span>
            <h3>Send it off.</h3>
            <p>
              Export the deterministic bid packet: scope pages, workbook,
              alerts, and a supplier-ready zip you can audit.
            </p>
          </article>
        </div>
      </div>
    </section>

    <div class="dither-edge" aria-hidden="true"></div>

    <!-- 7. Trust band: source-backed AI + free engine -->
    <section
      id="open-source"
      class="section dark"
      aria-labelledby="trust-title"
    >
      <div class="container split">
        <div class="reveal">
          <p class="eyebrow">SOURCE-BACKED AI</p>
          <h2 id="trust-title">AI that can't invent your numbers.</h2>
          <p class="lead">
            The model reads, classifies, summarizes, and drafts. Deterministic
            code writes every quantity from JSON you approved, tied to a
            source page. If a number is in the workbook, you can prove where
            it came from.
          </p>
        </div>
        <div class="engine-panel reveal" style="--reveal-delay: 120ms">
          <h3>The free engine underneath</h3>
          <p>
            contractor-bid is MIT-licensed and runs on your machine. The CLI
            and MCP server do the document work: triage, scope packets,
            workbook, alerts, supplier sendoff. Your IT team can read every
            line.
          </p>
          <div class="engine-actions">
            <button
              class="copy-command"
              type="button"
              data-copy={site.installCommand}
              data-label="Copy install"
            >
              <Clipboard size={18} aria-hidden="true" />
              <span data-copy-text>Copy install</span>
              <code>{site.installCommand}</code>
            </button>
            <a class="button ghost" href={site.docsUrl}>
              <BookOpen size={18} aria-hidden="true" />
              Read the docs
            </a>
          </div>
          <div class="path-grid" aria-label="Local workspace folders">
            <div class="path-box">
              <code>bid-docs/</code>
              <p>Yours, untouched. Plans, specs, forms, addenda.</p>
            </div>
            <div class="path-box">
              <code>bid-package-working/</code>
              <p>Generated, reviewable. Packets, workbook, alerts, zip.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="dither-edge flip" aria-hidden="true"></div>

    <!-- 8. Built by an estimator -->
    <section class="section tight" aria-labelledby="estimator-title">
      <div class="container split">
        <div class="reveal">
          <p class="eyebrow">BUILT BY AN ESTIMATOR</p>
          <h2 id="estimator-title">Not a VC takeoff fantasy.</h2>
        </div>
        <div class="quote-block reveal" style="--reveal-delay: 120ms">
          <p class="lead">
            I'm Keith Bloemendaal: 37 years in construction, master plumber,
            journeyman electrician, founded and sold a homebuilding company. I
            estimate commercial fence in Florida every week. I built this
            suite because I bid work weekly and got tired of the paper
            shuffle.
          </p>
        </div>
      </div>
    </section>

    <!-- 9. Pilot section -->
    <section id="pilot" class="section tight" aria-labelledby="pilot-title">
      <div class="container">
        <p class="eyebrow reveal">GET IN</p>
        <h2 id="pilot-title" class="reveal" style="--reveal-delay: 80ms">
          Pilot the app. The engine is free either way.
        </h2>
        <div class="cards stagger">
          <article class="card featured reveal">
            <h3>Pilot program</h3>
            <div class="price">In pilot</div>
            <ul>
              <li>First access to Contractor Takeoff</li>
              <li>Direct line to Keith while you run real bids</li>
              <li>Shape the roadmap with what you actually need</li>
              <li>Terms discussed on a call</li>
            </ul>
            <a
              class="button steel"
              href={site.pilotHref}
