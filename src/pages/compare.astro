---
import { ExternalLink, Mail } from "@lucide/astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteNav from "@/components/SiteNav.astro";
import { site } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";

const rows = [
  {
    category: "GC-side ITB tools",
    tools: "BuildingConnected, Downtobid",
    fit: "Great at what they do: GCs sending invites and distributing plan rooms. They serve the GC. Contractor Takeoff starts where they stop: the invite lands in your inbox and now the bid is your problem.",
  },
  {
    category: "Takeoff measurement",
    tools: "STACK, Togal",
    fit: "Strong dedicated measurement platforms. If they fit your trade, keep them. This suite does not auto-measure anything: in Plan Markup a human draws every measurement, and Contractor Takeoff organizes the bid around whatever tool produced the numbers.",
  },
  {
    category: "Measurement and markup",
    tools: "Bluebeam Revu",
    fit: "Revu is deeper, full stop. Plan Markup covers the 10% of Revu most estimators use daily: measure, count, markup, overlay, CSV totals. It exports Revu-compatible annotations, so a Revu shop can open your work. If you live in Revu's deep features, stay there.",
  },
  {
    category: "The status quo",
    tools: "Spreadsheets, email, shared folders",
    fit: "This is what Contractor Takeoff actually replaces. Bid status in a spreadsheet, addenda buried in email, plans scattered across folders. The bid board, per-bid document library, and dated decisions put all of it in one place.",
  },
];
---

<BaseLayout
  title="How the suite compares | Contractor Takeoff"
  description="An honest comparison of the Contractor Takeoff suite against GC-side ITB tools, takeoff measurement platforms, Bluebeam Revu, and the spreadsheet-and-folders status quo."
>
  <SiteNav />
  <main id="main-content">
    <section class="subpage-hero">
      <div class="container split">
        <div class="reveal">
          <p class="eyebrow">CMP 01 / COMPARE</p>
          <h1>It lives between the invite and the estimate.</h1>
        </div>
        <p class="lead reveal" style="--reveal-delay: 120ms">
          The suite is not a plan room, not a pricing engine, and not a
          computer-vision takeoff tool. Contractor Takeoff runs the bid from
          invite to sendoff, and Plan Markup handles the measuring and marking
          in between. Here is where everything else fits, honestly.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container reveal">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Category</th>
              <th>Common tools</th>
              <th>Where the suite fits</th>
            </tr>
          </thead>
          <tbody>
            {
              rows.map(row => (
                <tr>
                  <td><strong>{row.category}</strong></td>
                  <td>{row.tools}</td>
                  <td>{row.fit}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <div class="dither-edge" aria-hidden="true"></div>
    <section class="section tight dark">
      <div class="container split">
        <div class="reveal">
          <p class="eyebrow">CMP 02 / POSITIONING</p>
          <h2>Keep the tools you already trust.</h2>
        </div>
        <div class="reveal" style="--reveal-delay: 120ms">
          <p class="lead">
            The practical stack is boring: the GC's invite system, Contractor
            Takeoff as the bid command center, Plan Markup or your preferred
            measurement tool on the plans, then your estimating spreadsheet for
            pricing. Pricing stays your judgment. The suite makes the handoffs
            less chaotic.
          </p>
          <div class="section-actions">
            <a class="button safety" href={site.pilotHref}>
              <Mail size={18} aria-hidden="true" />
              Join the pilot
            </a>
            <a class="button secondary" href={site.docsUrl}>
              <ExternalLink size={18} aria-hidden="true" />
              Read the docs
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
