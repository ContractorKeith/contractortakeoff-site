      <p class="eyebrow">SETUP CALL</p>
      <h1>Redirecting to setup details.</h1>
      <p><a class="button orange" href="/dfy#booking">Go to setup</a></p>
    </div>
  </main>
  <script is:inline>
    window.location.replace("/dfy#booking");
  </script>
</BaseLayout>
